arch_wiki_index/

# Compiled Go binary - build locally with `go build -o qareen .` instead of
# committing a 15MB+ platform-specific binary to the repo.
/qareen

# Secrets - never commit a real API key.
.env

# Runtime data / logs generated by the daemon - these contain your actual
# personal activity history and should never end up in git.
*.db
*.db-shm
*.db-wal
*.log

# Python
__pycache__/
*.pyc
venv/
.venv/

# Go
*.test
*.out

# Firefox Extension Package
qareen.xpi


