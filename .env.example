# Copy this file to .env and fill in your own key, or export it directly in
# your shell profile (~/.zshrc / ~/.bashrc):
#
#   export GROQ_API_KEY="your-key-here"
#
# Get a free key at https://console.groq.com/keys
#
# NEVER commit a real key to git. .env is already excluded via .gitignore.
GROQ_API_KEY=
